<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>小米运动步数助手</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f4f4f9; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
        .container { background: white; padding: 2rem; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); width: 350px; }
        h2 { text-align: center; color: #ff6700; margin-bottom: 1.5rem; }
        .form-group { margin-bottom: 1rem; }
        label { display: block; margin-bottom: 0.5rem; color: #333; }
        input { width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 5px; box-sizing: border-box; }
        button { width: 100%; padding: 10px; background-color: #ff6700; color: white; border: none; border-radius: 5px; cursor: pointer; font-size: 16px; transition: background 0.3s; }
        button:hover { background-color: #e55c00; }
        button:disabled { background-color: #ccc; cursor: not-allowed; }
        #result { margin-top: 1.5rem; padding: 10px; border-radius: 5px; display: none; text-align: center; }
        .success { background-color: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
        .error { background-color: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
    </style>
</head>
<body>

<div class="container">
    <h2>🏃‍♂️ 步数助手</h2>
    <div class="form-group">
        <label for="account">账号 (手机号)</label>
        <input type="text" id="account" placeholder="请输入小米账号手机号">
    </div>
    <div class="form-group">
        <label for="password">密码</label>
        <input type="password" id="password" placeholder="请输入密码">
    </div>
    <div class="form-group">
        <label for="steps">目标步数</label>
        <input type="number" id="steps" value="30000" min="1000" max="98000">
    </div>
    <button id="submitBtn" onclick="submitSteps()">开始刷步</button>
    <div id="result"></div>
</div>

<script>
    async function submitSteps() {
        const account = document.getElementById('account').value;
        const password = document.getElementById('password').value;
        const steps = document.getElementById('steps').value;
        const btn = document.getElementById('submitBtn');
        const resultDiv = document.getElementById('result');

        if (!account || !password) {
            alert("请填写账号和密码");
            return;
        }

        // 重置状态
        btn.disabled = true;
        btn.innerText = "处理中...";
        resultDiv.style.display = 'none';
        resultDiv.className = '';

        try {
            const response = await fetch('/api/update_steps', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ account, password, steps })
            });

            const data = await response.json();
            
            resultDiv.style.display = 'block';
            if (data.status === 'success') {
                resultDiv.className = 'success';
                resultDiv.innerText = data.message;
            } else {
                resultDiv.className = 'error';
                resultDiv.innerText = data.message;
            }
        } catch (error) {
            resultDiv.style.display = 'block';
            resultDiv.className = 'error';
            resultDiv.innerText = "网络请求失败，请检查后端是否运行";
        } finally {
            btn.disabled = false;
            btn.innerText = "开始刷步";
        }
    }
</script>

</body>
</html>
